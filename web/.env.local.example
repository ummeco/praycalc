# PrayCalc — local environment variables
# Copy this file to .env.local and fill in values.
# .env.local is gitignored and never committed.

# Hasura GraphQL endpoint (local dev via nSelf)
NEXT_PUBLIC_HASURA_URL=https://api.local.nself.org:8443/v1/graphql

# Auth endpoint (local dev via nSelf)
NEXT_PUBLIC_AUTH_URL=https://auth.local.nself.org:8443

# Remote Schema secret (Hasura sends this when calling /api/graphql)
# Must match REMOTE_SCHEMA_SECRET in backend/.env.local
REMOTE_SCHEMA_SECRET=

# Sentry error monitoring DSN (leave blank to disable)
NEXT_PUBLIC_SENTRY_DSN=
